---
import { navItems, siteConfig } from "@/data/site";

const path = Astro.url.pathname;
const isActive = (href: string): boolean => {
  const base = href.split("#")[0];
  if (base === "/work") return path === "/work" || path.startsWith("/work/");
  return false;
};
---

<header class="site-header">
  <nav class="nav-shell" aria-label="Primary navigation">
    <a class="brand" href="/" aria-label={`${siteConfig.name} home`}>
      {siteConfig.name}
    </a>

    <div class="nav-right">
      <div class="nav-links">
        {
          navItems.map((item) => (
            <a
              href={item.href}
              aria-current={isActive(item.href) ? "page" : undefined}
            >
              {item.label}
            </a>
          ))
        }
      </div>

      <button
        class="theme-toggle"
        type="button"
        data-theme-toggle
        aria-label="Switch color theme"
        title="Switch color theme"
      >
        <svg
          class="icon-sun"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <circle cx="12" cy="12" r="4"></circle>
          <path
            d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M6.3 17.7l-1.4 1.4M19.1 4.9l-1.4 1.4"
          ></path>
        </svg>
        <svg
          class="icon-moon"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"></path>
        </svg>
      </button>
    </div>
  </nav>
</header>

<script>
  const toggle = document.querySelector("[data-theme-toggle]");
  toggle?.addEventListener("click", () => {
    const root = document.documentElement;
    const next = root.dataset.theme === "dark" ? "light" : "dark";
    root.dataset.theme = next;
    try {
      localStorage.setItem("theme", next);
    } catch {
      /* ignore storage failures (e.g. private mode) */
    }
  });
</script>
