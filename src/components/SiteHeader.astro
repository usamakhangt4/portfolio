---
import { navItems, siteConfig } from "@/data/site";

const path = Astro.url.pathname;
const isActive = (href: string): boolean => {
  const base = href.split("#")[0];
  if (base === "/work") return path === "/work" || path.startsWith("/work/");
  return false;
};
---

<header class="site-header">
  <nav class="nav-shell" aria-label="Primary navigation">
    <a class="brand" href="/" aria-label={`${siteConfig.name} home`}>
      {siteConfig.name}
    </a>

    <div class="nav-right">
      <div id="primary-nav-links" class="nav-links">
        {
          navItems.map((item) => (
            <a
              href={item.href}
              aria-current={isActive(item.href) ? "page" : undefined}
            >
              {item.label}
            </a>
          ))
        }
      </div>

      <div class="nav-controls">
        <button
          class="theme-toggle"
          type="button"
          data-theme-toggle
          aria-label="Switch to dark theme"
          aria-pressed="false"
          title="Switch to dark theme"
        >
          <svg
            class="icon-sun"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <circle cx="12" cy="12" r="4"></circle>
            <path
              d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M6.3 17.7l-1.4 1.4M19.1 4.9l-1.4 1.4"
            ></path>
          </svg>
          <svg
            class="icon-moon"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"></path>
          </svg>
        </button>

        <button
          class="nav-toggle"
          type="button"
          data-nav-toggle
          aria-label="Open navigation menu"
          aria-controls="primary-nav-links"
          aria-expanded="false"
        >
          <svg
            class="icon-menu"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            aria-hidden="true"
          >
            <path d="M4 7h16M4 12h16M4 17h16"></path>
          </svg>
          <svg
            class="icon-close"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            aria-hidden="true"
          >
            <path d="M6 6l12 12M18 6L6 18"></path>
          </svg>
        </button>
      </div>
    </div>
  </nav>
</header>

<script is:inline data-astro-rerun>
  (() => {
    const toggle = document.querySelector("[data-theme-toggle]");
    const nav = document.querySelector(".nav-shell");
    const navToggle = document.querySelector("[data-nav-toggle]");
    const navLinks = document.querySelector(".nav-links");

    const updateToggleState = () => {
      if (!(toggle instanceof HTMLButtonElement)) return;
      const current =
        document.documentElement.dataset.theme === "dark" ? "dark" : "light";
      const next = current === "dark" ? "light" : "dark";
      const label = `Switch to ${next} theme`;
      toggle.setAttribute("aria-label", label);
      toggle.setAttribute("title", label);
      toggle.setAttribute("aria-pressed", String(current === "dark"));
    };

    updateToggleState();
    toggle?.addEventListener("click", () => {
      const root = document.documentElement;
      const next = root.dataset.theme === "dark" ? "light" : "dark";
      root.dataset.theme = next;
      try {
        localStorage.setItem("theme", next);
      } catch {
        /* ignore storage failures (e.g. private mode) */
      }
      updateToggleState();
    });

    const setNavigationOpen = (open) => {
      if (!(nav instanceof HTMLElement)) return;
      if (!(navToggle instanceof HTMLButtonElement)) return;

      nav.dataset.navOpen = String(open);
      navToggle.setAttribute("aria-expanded", String(open));
      navToggle.setAttribute(
        "aria-label",
        open ? "Close navigation menu" : "Open navigation menu",
      );
    };

    navToggle?.addEventListener("click", () => {
      const open = navToggle.getAttribute("aria-expanded") !== "true";
      setNavigationOpen(open);
    });

    navLinks?.addEventListener("click", (event) => {
      if (event.target instanceof HTMLAnchorElement) setNavigationOpen(false);
    });

    document.addEventListener("keydown", (event) => {
      if (event.key !== "Escape") return;
      if (navToggle?.getAttribute("aria-expanded") !== "true") return;
      setNavigationOpen(false);
      if (navToggle instanceof HTMLButtonElement) navToggle.focus();
    });

    document.addEventListener("click", (event) => {
      if (!(event.target instanceof Node)) return;
      if (nav?.contains(event.target)) return;
      setNavigationOpen(false);
    });
  })();
</script>
