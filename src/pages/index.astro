---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import ProjectCard from "@/components/ProjectCard.astro";
import SiteFooter from "@/components/SiteFooter.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import { profilePageJsonLd } from "@/lib/seo";
import {
  careerHighlights,
  education,
  experience,
  professionalProjects,
  siteConfig,
  stackGroups,
} from "@/data/site";

const work = (await getCollection("work"))
  .filter((project) => !project.data.draft && project.data.featured)
  .sort((a, b) => a.data.order - b.data.order);

const flagshipWork = work.filter(
  (project) => (project.data.tier ?? "flagship") === "flagship",
);
const supportingWork = work.filter(
  (project) => project.data.tier === "supporting",
);

const featured = flagshipWork[0];
// The featured project is highlighted in the hero, so exclude it from the
// "Selected work" list below to avoid showing the same project twice.
const restOfFlagship = flagshipWork.slice(1);

// Show the real install command for the featured package as evidence.
const featuredNpm = featured?.data.links.find((l) => {
  try {
    return new URL(l.href).host.replace(/^www\./, "") === "npmjs.com";
  } catch {
    return false;
  }
});
const featuredCommand = featuredNpm
  ? `npm i ${decodeURIComponent(featuredNpm.href.replace(/\/$/, "").split("/package/")[1] ?? "")}`
  : null;
---

<BaseLayout canonicalPath="/" jsonLd={profilePageJsonLd()}>
  <SiteHeader />

  <main id="main-content" tabindex="-1">
    <section class="hero">
      <div class="section-shell">
        <div class="hero-inner">
          <p class="hero-role mono">{siteConfig.role}</p>
          <h1>{siteConfig.name}</h1>
          <p class="hero-lede">
            I lead frontend delivery for React and Next.js products, build
            reusable component systems, and publish tools other developers can
            install.
          </p>
          <p class="hero-location mono">
            {siteConfig.location} / {siteConfig.availability}
          </p>
          <div class="hero-actions">
            <a class="button button-primary" href="/work">View work</a>
            <a
              class="button"
              href={siteConfig.resume}
              target="_blank"
              rel="noopener noreferrer"
            >Resume</a>
            <a
              class="button button-text"
              href={siteConfig.social.linkedin}
              target="_blank"
              rel="noopener noreferrer"
            >LinkedIn ↗</a>
          </div>
        </div>

        {
          featured && (
            <a class="hero-feature" href={`/work/${featured.id}`}>
              <div class="hero-feature-label mono">Featured</div>
              <div class="hero-feature-frame">
                <div class="preview-chrome" aria-hidden="true">
                  <span></span><span></span><span></span>
                  <code class="mono">{featured.id}</code>
                </div>
              <div class="hero-feature-body">
                <p class="mono">{featured.data.type}</p>
                <strong>{featured.data.title}</strong>
                <p>{featured.data.summary}</p>
                {
                  featuredCommand && (
                    <code class="hero-feature-cmd mono">
                      <span class="evidence-prompt" aria-hidden="true">
                        ${" "}
                      </span>
                      {featuredCommand}
                    </code>
                  )
                }
              </div>
              </div>
            </a>
          )
        }
      </div>
    </section>

    <section class="section-shell career-highlights" aria-label="Career highlights">
      {careerHighlights.map((item) => (
        <div class="career-highlight">
          <strong>{item.value}</strong>
          <span>{item.label}</span>
        </div>
      ))}
    </section>

    <section id="experience" class="section-shell section-block experience-section">
      <div class="section-heading section-heading-wide">
        <p class="section-kicker mono">Professional experience</p>
        <h2>Seven years of shipping frontend products</h2>
        <p>
          From production workflows and analytics dashboards to team leadership
          and reusable component architecture across remote product teams.
        </p>
      </div>

      <div class="experience-list">
        {experience.map((item, index) => (
          <article class="experience-item">
            <div class="experience-meta">
              <span class="experience-index mono">
                {String(index + 1).padStart(2, "0")}
              </span>
              <span class="mono">{item.period}</span>
              <span>{item.location}</span>
            </div>
            <div class="experience-content">
              <h3>{item.role}</h3>
              <p class="experience-company">{item.company}</p>
              <p>{item.summary}</p>
              <ul>
                {item.highlights.map((highlight) => <li>{highlight}</li>)}
              </ul>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section id="professional-work" class="section-shell section-block professional-work-section">
      <div class="section-heading section-heading-wide">
        <p class="section-kicker mono">Professional work</p>
        <h2>Products built inside real teams</h2>
        <p>
          Selected commercial and institutional work. Details are intentionally
          focused on my contribution rather than proprietary implementation.
        </p>
      </div>

      <div class="professional-project-grid">
        {professionalProjects.map((project, index) => (
          <article class="professional-project-card">
            <div class="professional-project-heading">
              <span class="mono">{String(index + 1).padStart(2, "0")}</span>
              <span class="mono">{project.type}</span>
            </div>
            <h3>{project.title}</h3>
            <p>{project.description}</p>
            <ul aria-label={`${project.title} stack`}>
              {project.stack.map((item) => <li class="mono">{item}</li>)}
            </ul>
          </article>
        ))}
      </div>
    </section>

    <section id="work" class="section-shell section-block">
      <div class="section-heading section-heading-wide">
        <p class="section-kicker mono">Open source & independent work</p>
        <h2>Public proof, not just claims</h2>
        <p>Libraries and products with source, packages, demos, or live apps.</p>
      </div>

      <div class="project-list">
        {restOfFlagship.map((project, index) => (
          <ProjectCard project={project} index={index} />
        ))}
      </div>
    </section>

    <section id="stack" class="section-shell stack-section">
      <div class="stack-overview">
        <div class="stack-title-block">
          <p class="stack-eyebrow mono">Technical foundation</p>
          <h2>Stack</h2>
        </div>
        <p class="stack-summary">
          The tools and engineering practices I use to turn component ideas
          into durable, production-ready interfaces.
        </p>
      </div>

      <div class="stack-grid">
        {stackGroups.map((group, index) => (
          <article class="stack-card">
            <div class="stack-card-heading">
              <span class="stack-card-index mono">
                {String(index + 1).padStart(2, "0")}
              </span>
              <h3>{group.title}</h3>
            </div>
            <p>{group.description}</p>
            <ul aria-label={`${group.title} technologies`}>
              {group.items.map((item) => <li class="mono">{item}</li>)}
            </ul>
          </article>
        ))}
      </div>
    </section>

    {
      supportingWork.length > 0 && (
        <section id="more-work" class="section-shell section-block">
          <div class="section-heading">
            <h2>Also</h2>
            <p>Supporting apps and experiments.</p>
          </div>

          <div class="project-list project-list-compact">
            {supportingWork.map((project, index) => (
              <ProjectCard project={project} index={index} />
            ))}
          </div>
        </section>
      )
    }

    <section class="section-shell education-section" aria-labelledby="education-title">
      <div>
        <p class="section-kicker mono">Education</p>
        <h2 id="education-title">{education.degree}</h2>
        <p>{education.school}</p>
      </div>
      <span class="education-period mono">{education.period}</span>
    </section>
  </main>

  <SiteFooter />
</BaseLayout>
