---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import ProjectCard from "@/components/ProjectCard.astro";
import SiteFooter from "@/components/SiteFooter.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import { profilePageJsonLd } from "@/lib/seo";
import { siteConfig, stackLine } from "@/data/site";

const work = (await getCollection("work"))
  .filter((project) => project.data.featured)
  .sort((a, b) => a.data.order - b.data.order);

const flagshipWork = work.filter(
  (project) => (project.data.tier ?? "flagship") === "flagship",
);
const supportingWork = work.filter(
  (project) => project.data.tier === "supporting",
);

const featured = flagshipWork[0];
---

<BaseLayout canonicalPath="/" jsonLd={profilePageJsonLd()}>
  <SiteHeader />

  <main>
    <section class="hero">
      <div class="hero-inner section-shell">
        <p class="hero-role mono">Frontend Engineer</p>
        <h1>{siteConfig.name}</h1>
        <p class="hero-lede">
          I publish typed React libraries and ship Next.js product UIs —
          virtualized trees, Web Components, and tools people can install.
        </p>
        <div class="hero-actions">
          <a class="button button-primary" href="#work">Selected work</a>
          <a class="button" href={`mailto:${siteConfig.email}`}>Email</a>
        </div>
      </div>

      {
        featured && (
          <a class="hero-feature section-shell" href={`/work/${featured.id}`}>
            <div class="hero-feature-label mono">Featured</div>
            <div class="hero-feature-frame">
              <div class="preview-chrome" aria-hidden="true">
                <span></span><span></span><span></span>
                <code class="mono">{featured.id}</code>
              </div>
              <div class="hero-feature-body">
                <p class="mono">{featured.data.type}</p>
                <strong>{featured.data.title}</strong>
                <p>{featured.data.summary}</p>
              </div>
            </div>
          </a>
        )
      }
    </section>

    <section id="work" class="section-shell section-block">
      <div class="section-heading">
        <h2>Selected work</h2>
        <p>Libraries and products with public source, demos, or live apps.</p>
      </div>

      <div class="project-list">
        {flagshipWork.map((project, index) => (
          <ProjectCard project={project} index={index} />
        ))}
      </div>
    </section>

    <section id="stack" class="section-shell section-block stack-section">
      <div class="section-heading">
        <h2>Stack</h2>
        <p>What shows up repeatedly in the work above.</p>
      </div>
      <ul class="stack-line" aria-label="Primary stack">
        {stackLine.map((item) => <li class="mono">{item}</li>)}
      </ul>
    </section>

    {
      supportingWork.length > 0 && (
        <section id="more-work" class="section-shell section-block">
          <div class="section-heading">
            <h2>Also</h2>
            <p>Supporting apps and experiments.</p>
          </div>

          <div class="project-list project-list-compact">
            {supportingWork.map((project, index) => (
              <ProjectCard project={project} index={index} />
            ))}
          </div>
        </section>
      )
    }
  </main>

  <SiteFooter />
</BaseLayout>
