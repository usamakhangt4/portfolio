---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import ProjectCard from "@/components/ProjectCard.astro";
import SiteFooter from "@/components/SiteFooter.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import { profilePageJsonLd } from "@/lib/seo";
import { siteConfig, stackGroups } from "@/data/site";

const work = (await getCollection("work"))
  .filter((project) => !project.data.draft && project.data.featured)
  .sort((a, b) => a.data.order - b.data.order);

const flagshipWork = work.filter(
  (project) => (project.data.tier ?? "flagship") === "flagship",
);
const supportingWork = work.filter(
  (project) => project.data.tier === "supporting",
);

const featured = flagshipWork[0];
// The featured project is highlighted in the hero, so exclude it from the
// "Selected work" list below to avoid showing the same project twice.
const restOfFlagship = flagshipWork.slice(1);

// Show the real install command for the featured package as evidence.
const featuredNpm = featured?.data.links.find((l) => {
  try {
    return new URL(l.href).host.replace(/^www\./, "") === "npmjs.com";
  } catch {
    return false;
  }
});
const featuredCommand = featuredNpm
  ? `npm i ${decodeURIComponent(featuredNpm.href.replace(/\/$/, "").split("/package/")[1] ?? "")}`
  : null;
---

<BaseLayout canonicalPath="/" jsonLd={profilePageJsonLd()}>
  <SiteHeader />

  <main id="main-content" tabindex="-1">
    <section class="hero">
      <div class="section-shell">
        <div class="hero-inner">
          <p class="hero-role mono">Frontend Engineer</p>
          <h1>{siteConfig.name}</h1>
          <p class="hero-lede">
            I publish typed React libraries and ship Next.js product UIs —
            virtualized trees, Web Components, and tools people can install.
          </p>
          <div class="hero-actions">
            <a class="button button-primary" href="#work">Selected work</a>
            <a class="button" href={`mailto:${siteConfig.email}`}>Email</a>
          </div>
        </div>

        {
          featured && (
            <a class="hero-feature" href={`/work/${featured.id}`}>
              <div class="hero-feature-label mono">Featured</div>
              <div class="hero-feature-frame">
                <div class="preview-chrome" aria-hidden="true">
                  <span></span><span></span><span></span>
                  <code class="mono">{featured.id}</code>
                </div>
              <div class="hero-feature-body">
                <p class="mono">{featured.data.type}</p>
                <strong>{featured.data.title}</strong>
                <p>{featured.data.summary}</p>
                {
                  featuredCommand && (
                    <code class="hero-feature-cmd mono">
                      <span class="evidence-prompt" aria-hidden="true">
                        ${" "}
                      </span>
                      {featuredCommand}
                    </code>
                  )
                }
              </div>
              </div>
            </a>
          )
        }
      </div>
    </section>

    <section id="work" class="section-shell section-block">
      <div class="section-heading">
        <h2>Selected work</h2>
        <p>Libraries and products with public source, demos, or live apps.</p>
      </div>

      <div class="project-list">
        {restOfFlagship.map((project, index) => (
          <ProjectCard project={project} index={index} />
        ))}
      </div>
    </section>

    <section id="stack" class="section-shell stack-section">
      <div class="stack-overview">
        <div class="stack-title-block">
          <p class="stack-eyebrow mono">Technical foundation</p>
          <h2>Stack</h2>
        </div>
        <p class="stack-summary">
          The tools and engineering practices I use to turn component ideas
          into durable, production-ready interfaces.
        </p>
      </div>

      <div class="stack-grid">
        {stackGroups.map((group, index) => (
          <article class="stack-card">
            <div class="stack-card-heading">
              <span class="stack-card-index mono">
                {String(index + 1).padStart(2, "0")}
              </span>
              <h3>{group.title}</h3>
            </div>
            <p>{group.description}</p>
            <ul aria-label={`${group.title} technologies`}>
              {group.items.map((item) => <li class="mono">{item}</li>)}
            </ul>
          </article>
        ))}
      </div>
    </section>

    {
      supportingWork.length > 0 && (
        <section id="more-work" class="section-shell section-block">
          <div class="section-heading">
            <h2>Also</h2>
            <p>Supporting apps and experiments.</p>
          </div>

          <div class="project-list project-list-compact">
            {supportingWork.map((project, index) => (
              <ProjectCard project={project} index={index} />
            ))}
          </div>
        </section>
      )
    }
  </main>

  <SiteFooter />
</BaseLayout>
