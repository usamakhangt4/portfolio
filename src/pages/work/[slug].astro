---
import { getCollection, render, type CollectionEntry } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import SiteFooter from "@/components/SiteFooter.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import { breadcrumbJsonLd, creativeWorkJsonLd } from "@/lib/seo";

export async function getStaticPaths() {
  const projects = (await getCollection("work")).filter(
    (project) => !project.data.draft,
  );

  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

interface Props {
  project: CollectionEntry<"work">;
}

const { project } = Astro.props;
const { Content } = await render(project);
const { data } = project;
---

<BaseLayout
  title={data.seo.title}
  description={data.seo.description}
  canonicalPath={`/work/${project.id}`}
  jsonLd={[breadcrumbJsonLd(project), creativeWorkJsonLd(project)]}
>
  <SiteHeader />

  <main id="main-content" tabindex="-1">
    <section class="case-hero section-shell">
      <a class="back-link" href="/work">← Work</a>
      <p class="mono-type">{data.type}</p>
      <h1>{data.title}</h1>
      <p>{data.summary}</p>

      <div class="case-actions">
        {data.links.map((link) => (
          <a class="button" href={link.href} rel="noopener noreferrer">{link.label}</a>
        ))}
      </div>
    </section>

    <dl class="case-meta section-shell" aria-label="Project details">
      <div>
        <dt>Role</dt>
        <dd>{data.role}</dd>
      </div>
      <div>
        <dt>Year</dt>
        <dd>{data.year}</dd>
      </div>
      <div>
        <dt>Stack</dt>
        <dd>{data.stack.join(", ")}</dd>
      </div>
    </dl>

    <section class="section-shell case-layout">
      <aside class="case-sidebar">
        <h2>Highlights</h2>
        <ul>
          {data.highlights.map((item) => <li>{item}</li>)}
        </ul>
      </aside>

      <article class="prose">
        <Content />
      </article>
    </section>
  </main>

  <SiteFooter />
</BaseLayout>
